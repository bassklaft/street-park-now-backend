# ─── DATABASE ─────────────────────────────────────────────────────────────────
# From Render PostgreSQL dashboard → "Connection String"
DATABASE_URL=postgresql://user:password@host:5432/parkwatch

# ─── TWILIO ───────────────────────────────────────────────────────────────────
# From console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# The phone number you buy in Twilio (~$1/mo)
TWILIO_PHONE_NUMBER=+19175550100

# ─── STRIPE ───────────────────────────────────────────────────────────────────
# From dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
# From dashboard.stripe.com → Products → (create products, copy Price ID)
STRIPE_PRICE_MONTHLY=price_xxxxxxxxxxxxxxxx   # $2.99/mo
STRIPE_PRICE_ANNUAL=price_xxxxxxxxxxxxxxxx    # $19/yr
# From Stripe → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ─── APP ──────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://streetparkinfo.vercel.app
# Your Render service URL (for self-ping keepalive)
RENDER_SERVICE_URL=street-park-info-backend.onrender.com
# Random string for admin endpoint protection
ADMIN_SECRET=make_this_long_and_random_123

# ─── PORT (Render sets this automatically) ────────────────────────────────────
PORT=3001
